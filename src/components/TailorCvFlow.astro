---
import type { Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

const labels = isHe
  ? {
      cv: 'קו״ח',
      job: 'משרה',
      extract: 'חילוץ',
      facts: 'עובדות',
      reqs: 'דרישות',
      map: 'מיפוי',
      mapSub: 'עדויות ↔ דרישות',
      rewrite: 'כתיבה מחדש',
      rewriteSub: 'עם guardrail',
      guard: 'חסם הזיות',
      output: 'קו״ח מותאמים',
      outputSub: '+ מכתב נלווה',
      caption: 'כל שלב מעוגן בעדות — ה־guardrail חוסם כל הצהרה שלא קיימת בקו״ח המקור.',
      title: 'מבנה — TailorCV',
    }
  : {
      cv: 'CV',
      job: 'Job spec',
      extract: 'Extract',
      facts: 'Facts',
      reqs: 'Requirements',
      map: 'Map',
      mapSub: 'Evidence ↔ Reqs',
      rewrite: 'Rewrite',
      rewriteSub: 'with guardrail',
      guard: 'Fabrication guard',
      output: 'Tailored CV',
      outputSub: '+ cover letter',
      caption: 'Every step is anchored in evidence — the guardrail blocks any claim not present in the source CV.',
      title: 'How it flows — TailorCV',
    };
---

<figure class="mt-6">
  <p class="mono text-[0.65rem] tracking-[0.16em] uppercase text-muted mb-2">
    {labels.title}
  </p>
  <div class="arch-frame">
    <svg
      class="arch-svg"
      viewBox="0 0 880 260"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label={labels.caption}
    >
      <defs>
        <marker
          id="arrow-head"
          viewBox="0 0 10 10"
          refX="8"
          refY="5"
          markerWidth="6"
          markerHeight="6"
          orient="auto-start-reverse"
        >
          <path d="M0,0 L10,5 L0,10 z" fill="var(--color-muted)" />
        </marker>
      </defs>

      {/* CV input */}
      <g>
        <rect x="20" y="60" width="120" height="46" rx="6"
              fill="var(--color-paper-soft)" stroke="var(--color-rule)" stroke-width="1.2"/>
        <text x="80" y="78" text-anchor="middle"
              font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5"
              fill="var(--color-muted)">INPUT</text>
        <text x="80" y="96" text-anchor="middle"
              font-family="Space Grotesk, Inter, sans-serif" font-weight="600" font-size="15"
              fill="var(--color-ink)">{labels.cv}</text>
      </g>

      {/* Job spec input */}
      <g>
        <rect x="20" y="158" width="120" height="46" rx="6"
              fill="var(--color-paper-soft)" stroke="var(--color-rule)" stroke-width="1.2"/>
        <text x="80" y="176" text-anchor="middle"
              font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="1.5"
              fill="var(--color-muted)">INPUT</text>
        <text x="80" y="194" text-anchor="middle"
              font-family="Space Grotesk, Inter, sans-serif" font-weight="600" font-size="15"
              fill="var(--color-ink)">{labels.job}</text>
      </g>

      {/* Converging arrows to Extract */}
      <path d="M 140 83 C 175 83, 175 132, 210 132"
            fill="none" stroke="var(--color-muted)" stroke-width="1.4"
            marker-end="url(#arrow-head)" />
      <path d="M 140 181 C 175 181, 175 132, 210 132"
            fill="none" stroke="var(--color-muted)" stroke-width="1.4"
            marker-end="url(#arrow-head)" />

      {/* Extract */}
      <g>
        <rect x="215" y="98" width="140" height="68" rx="6"
              fill="var(--color-paper)" stroke="var(--color-ink)" stroke-width="1.4"/>
        <text x="285" y="120" text-anchor="middle"
              font-family="Space Grotesk, Inter, sans-serif" font-weight="600" font-size="15"
              fill="var(--color-ink)">{labels.extract}</text>
        <text x="285" y="140" text-anchor="middle"
              font-family="Inter, sans-serif" font-size="11"
              fill="var(--color-muted)">{labels.facts}</text>
        <text x="285" y="155" text-anchor="middle"
              font-family="Inter, sans-serif" font-size="11"
              fill="var(--color-muted)">{labels.reqs}</text>
      </g>

      {/* Arrow Extract → Map */}
      <path d="M 355 132 L 405 132"
            fill="none" stroke="var(--color-muted)" stroke-width="1.4"
            marker-end="url(#arrow-head)" />

      {/* Map */}
      <g>
        <rect x="410" y="98" width="140" height="68" rx="6"
              fill="var(--color-paper)" stroke="var(--color-ink)" stroke-width="1.4"/>
        <text x="480" y="120" text-anchor="middle"
              font-family="Space Grotesk, Inter, sans-serif" font-weight="600" font-size="15"
              fill="var(--color-ink)">{labels.map}</text>
        <text x="480" y="148" text-anchor="middle"
              font-family="Inter, sans-serif" font-size="11"
              fill="var(--color-muted)">{labels.mapSub}</text>
      </g>

      {/* Arrow Map → Rewrite */}
      <path d="M 550 132 L 600 132"
            fill="none" stroke="var(--color-muted)" stroke-width="1.4"
            marker-end="url(#arrow-head)" />

      {/* Rewrite */}
      <g>
        <rect x="605" y="98" width="140" height="68" rx="6"
              fill="var(--color-paper)" stroke="var(--color-accent)" stroke-width="1.6"/>
        <text x="675" y="120" text-anchor="middle"
              font-family="Space Grotesk, Inter, sans-serif" font-weight="600" font-size="15"
              fill="var(--color-ink)">{labels.rewrite}</text>
        <text x="675" y="148" text-anchor="middle"
              font-family="Inter, sans-serif" font-size="11"
              fill="var(--color-accent-deep)">{labels.rewriteSub}</text>
      </g>

      {/* Guardrail badge above Rewrite */}
      <g>
        <rect x="615" y="40" width="120" height="26" rx="13"
              fill="var(--color-accent)" />
        <text x="675" y="57" text-anchor="middle"
              font-family="Inter, sans-serif" font-weight="600" font-size="11"
              fill="#faf6ef">⚠ {labels.guard}</text>
        <path d="M 675 66 L 675 96"
              stroke="var(--color-accent)" stroke-width="1.4"
              stroke-dasharray="3 3" />
      </g>

      {/* Arrow Rewrite → Output */}
      <path d="M 745 132 L 800 132"
            fill="none" stroke="var(--color-muted)" stroke-width="1.4"
            marker-end="url(#arrow-head)" />

      {/* Output (no full box — open ended on the right) */}
      <g>
        <text x="805" y="125"
              font-family="Space Grotesk, Inter, sans-serif" font-weight="600" font-size="13"
              fill="var(--color-ink)">{labels.output}</text>
        <text x="805" y="142"
              font-family="Inter, sans-serif" font-size="11"
              fill="var(--color-muted)">{labels.outputSub}</text>
      </g>
    </svg>
  </div>
  <figcaption class="arch-caption">{labels.caption}</figcaption>
</figure>

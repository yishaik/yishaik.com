---
import type { Locale } from '../i18n/index';
import { t, getLocalePath, getAlternateLocale } from '../i18n/index';
import ThemeToggle from './ThemeToggle.tsx';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const altLocale = getAlternateLocale(locale);
const altPath = getLocalePath(altLocale);

const navItems = [
  { key: 'why', href: '#why-yishai' },
  { key: 'work', href: '#selected-work' },
  { key: 'experience', href: '#experience' },
  { key: 'contact', href: '#contact' },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <nav class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-18 items-center justify-between">
      <a href={getLocalePath(locale)} class="text-lg font-semibold tracking-[-0.03em] text-ink">
        YK
      </a>

      <div class="hidden items-center gap-6 md:flex">
        {navItems.map((item) => (
          <a href={item.href} class="text-sm font-medium text-muted transition-colors hover:text-accent-dark dark:hover:text-accent-light">
            {t(locale, `nav.${item.key}`)}
          </a>
        ))}

        <div class="ml-2 flex items-center gap-3 border-l border-black/8 pl-4 dark:border-white/10">
          <ThemeToggle client:load />
          <a
            href={altPath}
            class="rounded-lg border border-black/8 px-3 py-2 text-sm font-medium text-muted transition-colors hover:border-blue-200 hover:text-accent-dark dark:border-white/10 dark:hover:border-blue-400/30 dark:hover:text-accent-light"
          >
            {t(locale, 'lang.switch')}
          </a>
        </div>
      </div>

      <button id="mobile-menu-btn" class="rounded-lg border border-black/8 p-2 text-muted md:hidden dark:border-white/10" aria-label="Menu">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden pb-4 md:hidden">
      <div class="space-y-2 rounded-2xl border border-black/8 bg-paper-soft/90 p-3 shadow-sm dark:border-white/10 dark:bg-surface-light/95">
        {navItems.map((item) => (
          <a href={item.href} class="mobile-nav-link block rounded-lg px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-white/60 hover:text-accent-dark dark:hover:bg-white/5 dark:hover:text-accent-light">
            {t(locale, `nav.${item.key}`)}
          </a>
        ))}
        <div class="mt-2 flex items-center gap-3 border-t border-black/8 px-2 pt-3 dark:border-white/10">
          <ThemeToggle client:load />
          <a
            href={altPath}
            class="rounded-lg border border-black/8 px-3 py-2 text-sm font-medium text-muted transition-colors hover:border-blue-200 hover:text-accent-dark dark:border-white/10 dark:hover:border-blue-400/30 dark:hover:text-accent-light"
          >
            {t(locale, 'lang.switch')}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });

  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 24) {
      header?.classList.add('bg-paper/85', 'backdrop-blur-lg', 'border-b', 'border-black/8', 'shadow-sm');
      header?.classList.remove('dark:bg-surface/90');
    } else {
      header?.classList.remove('bg-paper/85', 'backdrop-blur-lg', 'border-b', 'border-black/8', 'shadow-sm');
    }
  });
</script>

---
import type { Locale } from '../i18n/index';
import { getLocalePath, getAlternateLocale } from '../i18n/index';
import { general } from '../content/site';
import ThemeToggle from './ThemeToggle.tsx';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const altLocale = getAlternateLocale(locale);
const altPath = getLocalePath(altLocale);

const navItems = [
  { href: '#about', label: general.nav.about[locale] },
  { href: '#experience', label: general.nav.experience[locale] },
  { href: '#skills', label: general.nav.skills[locale] },
  { href: '#contact', label: general.nav.contact[locale] },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-30 transition-[background,border-color,backdrop-filter] duration-200">
  <div class="page-shell flex h-16 items-center justify-between gap-4">
    <a
      href={getLocalePath(locale)}
      class="inline-flex items-center gap-2 text-[0.92rem] font-medium text-ink hover:text-accent transition-colors"
    >
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
      {general.name.en}
    </a>

    <nav class="hidden md:flex items-center gap-5 text-sm">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-nav-link={item.href.replace('#', '')}
          class="nav-link"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1.5">
      <a href="#contact" class="btn btn-ghost btn-sm md:hidden">
        {general.nav.contact[locale]}
      </a>
      <div class="mx-1 h-5 w-px hidden sm:block" style="background:var(--color-rule)"></div>
      <ThemeToggle client:load />
      <a
        href={altPath}
        class="mono rounded-md border border-[color:var(--color-rule)] px-2 py-1 text-[0.72rem] text-muted transition-colors hover:text-ink hover:border-[color:var(--color-ink)]"
      >
        {general.langSwitch[locale]}
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const scroll = () => {
    if (!header) return;
    if (window.scrollY > 12) {
      header.style.background = 'color-mix(in srgb, var(--color-paper) 80%, transparent)';
      header.style.backdropFilter = 'blur(12px)';
      header.style.borderBottom = '1px solid var(--color-rule)';
    } else {
      header.style.background = 'transparent';
      header.style.backdropFilter = 'none';
      header.style.borderBottom = '1px solid transparent';
    }
  };
  window.addEventListener('scroll', scroll, { passive: true });
  scroll();

  // Scroll-spy: highlight the nav item for the section currently in view.
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'));
  const sectionIds = navLinks.map((l) => l.dataset.navLink).filter(Boolean) as string[];
  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  if (sections.length && 'IntersectionObserver' in window) {
    const setActive = (id: string) => {
      navLinks.forEach((l) => l.classList.toggle('is-active', l.dataset.navLink === id));
    };
    const spy = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) setActive(visible.target.id);
      },
      { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
    );
    sections.forEach((s) => spy.observe(s));
  }
</script>

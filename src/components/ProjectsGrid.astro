---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { projects } from '../content/projects';
import ProjectCard from './ProjectCard.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const sortedProjects = [...projects].sort((a, b) => Number(b.featured) - Number(a.featured));

const categories = [
  { key: 'all', label: t(locale, 'projects.filterAll') },
  { key: 'ai', label: t(locale, 'projects.filterAI') },
  { key: 'web', label: t(locale, 'projects.filterWeb') },
  { key: 'mobile', label: t(locale, 'projects.filterMobile') },
  { key: 'tools', label: t(locale, 'projects.filterTools') },
];
---

<section id="projects" class="section-container">
  <div class="text-center mb-10">
    <h2 class="section-title"><span class="gradient-text">{t(locale, 'projects.title')}</span></h2>
  </div>

  <div class="flex flex-wrap gap-2 justify-center mb-8" id="project-filters">
    {categories.map((cat) => (
      <button
        data-filter={cat.key}
        class={`filter-btn px-4 py-2 text-sm font-medium rounded-lg border transition-all ${
          cat.key === 'all'
            ? 'bg-accent text-white border-accent shadow-lg shadow-accent/20'
            : 'bg-slate-900/40 border-slate-700 text-slate-300 hover:border-indigo-400/60 light:bg-white/80 light:border-slate-300 light:text-slate-700'
        }`}
      >
        {cat.label}
      </button>
    ))}
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
    {sortedProjects.map((project) => (
      <div data-category={project.category} class="project-item">
        <ProjectCard project={project} locale={locale} />
      </div>
    ))}
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.project-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove('bg-accent', 'text-white', 'border-accent', 'shadow-lg', 'shadow-accent/20');
        b.classList.add('bg-slate-900/40', 'border-slate-700', 'text-slate-300', 'light:bg-white/80', 'light:border-slate-300', 'light:text-slate-700');
      });

      btn.classList.add('bg-accent', 'text-white', 'border-accent', 'shadow-lg', 'shadow-accent/20');
      btn.classList.remove('bg-slate-900/40', 'border-slate-700', 'text-slate-300', 'light:bg-white/80', 'light:border-slate-300', 'light:text-slate-700');

      items.forEach((item) => {
        const category = (item as HTMLElement).dataset.category;
        (item as HTMLElement).style.display = filter === 'all' || category === filter ? '' : 'none';
      });
    });
  });
</script>

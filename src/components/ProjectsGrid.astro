---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { projects } from '../content/projects';
import ProjectCard from './ProjectCard.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// Sort: featured first
const sortedProjects = [...projects].sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));

const categories = [
  { key: 'all', label: t(locale, 'projects.filterAll') },
  { key: 'ai', label: t(locale, 'projects.filterAI') },
  { key: 'web', label: t(locale, 'projects.filterWeb') },
  { key: 'mobile', label: t(locale, 'projects.filterMobile') },
  { key: 'tools', label: t(locale, 'projects.filterTools') },
];
---

<section id="projects" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
    <span class="gradient-text">{t(locale, 'projects.title')}</span>
  </h2>

  <!-- Filter tabs -->
  <div class="flex flex-wrap gap-2 justify-center mb-8" id="project-filters">
    {categories.map((cat) => (
      <button
        data-filter={cat.key}
        class={`filter-btn px-4 py-2 text-sm font-medium rounded-lg transition-all ${
          cat.key === 'all'
            ? 'bg-accent text-white shadow-lg shadow-accent/25'
            : 'bg-surface-light text-slate-300 hover:bg-surface-lighter border border-slate-700'
        }`}
      >
        {cat.label}
      </button>
    ))}
  </div>

  <!-- Projects grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
    {sortedProjects.map((project) => (
      <div data-category={project.category} class="project-item">
        <ProjectCard project={project} locale={locale} />
      </div>
    ))}
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.project-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      // Update active button
      buttons.forEach((b) => {
        b.classList.remove('bg-accent', 'text-white', 'shadow-lg', 'shadow-accent/25');
        b.classList.add('bg-surface-light', 'text-slate-300', 'border', 'border-slate-700');
      });
      btn.classList.add('bg-accent', 'text-white', 'shadow-lg', 'shadow-accent/25');
      btn.classList.remove('bg-surface-light', 'text-slate-300', 'border', 'border-slate-700');

      // Filter projects
      items.forEach((item) => {
        const category = (item as HTMLElement).dataset.category;
        if (filter === 'all' || category === filter) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

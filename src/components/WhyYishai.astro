---
import type { Locale } from '../i18n/index';
import { whyYishaiContent } from '../content/whyYishai';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="why-yishai" class="section-container">
  <div class="max-w-3xl">
    <div class="section-kicker">{whyYishaiContent.kicker[locale]}</div>
    <h2 class="section-title mt-5">{whyYishaiContent.title[locale]}</h2>
    <p class="section-lede mt-6 max-w-3xl">{whyYishaiContent.intro[locale]}</p>
  </div>

  <div class="mt-10 grid gap-5 lg:grid-cols-3">
    {whyYishaiContent.pillars.map((pillar) => (
      <article class="card h-full">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent-dark dark:text-accent-light">
          {locale === 'he' ? 'עמוד תווך' : 'Pillar'}
        </p>
        <h3 class="mt-4 text-xl font-semibold tracking-[-0.02em] text-ink">{pillar.title[locale]}</h3>
        <p class="mt-3 text-sm leading-7 text-muted sm:text-base">{pillar.body[locale]}</p>
      </article>
    ))}
  </div>
</section>

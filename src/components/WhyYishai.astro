---
import type { Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const intro = locale === 'he'
  ? 'היתרון שלי הוא לא רק ב-AI, ולא רק ב-IT. הוא בשילוב ביניהם — לקחת בעיות אמיתיות, לתרגם אותן למערכות שימושיות, ולחבר בין אוטומציה, תפעול, ותוצרים שאפשר באמת להפעיל.'
  : 'The differentiator is not just AI, and not just IT. It is the combination: taking real operational problems, translating them into useful systems, and connecting automation, infrastructure, and delivery that can actually run in the real world.';

const pillars = locale === 'he'
  ? [
      {
        title: 'AI עם כיוון פרקטי',
        body: 'ממוקד במערכות שעוזרות לאנשים לעבוד טוב יותר — לא רק בדמו מרשים או צ׳אטבוט חד-פעמי.',
      },
      {
        title: 'חשיבה מערכתית ואוטומציה',
        body: 'מזהה צווארי בקבוק, ממפה תהליכים, ובונה כלים פנימיים שמורידים חיכוך ומשפרים קצב עבודה.',
      },
      {
        title: 'עומק תשתיתי ותפעולי',
        body: 'מביא ניסיון אמיתי בסביבות enterprise, תמיכה ברמה גבוהה, ענן, אבטחה ותפעול טכני.',
      },
    ]
  : [
      {
        title: 'Applied AI, not demo AI',
        body: 'Focused on systems that help teams operate better — not just flashy prototypes or one-off chat experiences.',
      },
      {
        title: 'Systems thinking and automation',
        body: 'Looks for bottlenecks, maps workflows, and builds internal tools that reduce friction and improve execution speed.',
      },
      {
        title: 'Real infrastructure depth',
        body: 'Brings hands-on experience from enterprise environments, senior support, cloud, security, and technical operations.',
      },
    ];
---

<section id="why-yishai" class="section-container">
  <div class="max-w-3xl">
    <div class="section-kicker">{locale === 'he' ? 'למה ישי' : 'Why Yishai'}</div>
    <h2 class="section-title mt-5">
      {locale === 'he' ? 'לא עוד פרופיל AI גנרי — אלא builder שיודע גם לבנות וגם להפעיל.' : 'Not another generic AI profile — a builder who knows how to build and how to operate.'}
    </h2>
    <p class="section-lede mt-6 max-w-3xl">{intro}</p>
  </div>

  <div class="mt-10 grid gap-5 lg:grid-cols-3">
    {pillars.map((pillar) => (
      <article class="card h-full">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent-dark dark:text-accent-light">
          {locale === 'he' ? 'עמוד תווך' : 'Pillar'}
        </p>
        <h3 class="mt-4 text-xl font-semibold tracking-[-0.02em] text-ink">{pillar.title}</h3>
        <p class="mt-3 text-sm leading-7 text-muted sm:text-base">{pillar.body}</p>
      </article>
    ))}
  </div>
</section>

---
import type { Locale } from '../i18n/index';
import { experience } from '../content/experience';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';
---

<section id="experience" class="section page-shell">
  <p class="section-label mb-10">04 / {isHe ? 'ניסיון' : 'Experience'}</p>

  <div class="grid gap-12 lg:grid-cols-[minmax(0,0.4fr)_minmax(0,0.6fr)] lg:gap-14 mb-10 lg:mb-12">
    <h2 class="display display-md max-w-xl">
      {isHe
        ? 'רצף ארוך של תפקידים — תמיכה, פוסט־סייל, IT ותפעול טכני.'
        : 'A long arc of customer-facing engineering, support, IT, and operations roles.'}
    </h2>
    <p class="prose-body max-w-xl lg:pt-3">
      {isHe
        ? 'ההיסטוריה הזו חשובה כי היא מסבירה למה ה־AI יישומי שאני בונה עומד על קרקע אמיתית: מי הלקוח, מה עובר עליו, ומה אומר באמת "להפעיל בפרודקשן".'
        : 'This history matters because it explains why the applied AI work sits on real ground: who the customer is, what they actually live with, and what "run it in production" actually means.'}
    </p>
  </div>

  <div class="border-t border-[color:var(--color-rule)]">
    {experience.map((exp) => (
      <article id={`exp-${exp.slug}`} class="entry scroll-mt-28">
        <header>
          <p class="mono text-xs tracking-[0.08em] text-muted">{exp.period}</p>
        </header>
        <div>
          <h3 class="display text-xl text-ink leading-tight">{exp.role[locale]}</h3>
          <p class="mt-1 text-sm text-accent">{exp.company[locale]}</p>
          <p class="mt-3 text-sm leading-7 text-muted max-w-2xl">{exp.description[locale]}</p>
          {exp.highlights[locale].length > 0 && (
            <ul class="mt-4 space-y-1.5 max-w-2xl">
              {exp.highlights[locale].map((h) => (
                <li class="flex gap-3 text-sm leading-6 text-muted-soft">
                  <span class="mono text-[0.7rem] text-muted pt-1 select-none" aria-hidden="true">·</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

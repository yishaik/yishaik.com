---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { experience } from '../content/experience';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="experience" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
    <span class="gradient-text">{t(locale, 'experience.title')}</span>
  </h2>

  <div class="relative max-w-3xl mx-auto">
    <!-- Vertical line -->
    <div class="absolute top-0 bottom-0 left-4 md:left-1/2 md:-translate-x-px w-0.5 bg-gradient-to-b from-accent via-purple-500 to-transparent"></div>

    {experience.map((exp, index) => (
      <div class={`relative flex items-start mb-12 last:mb-0 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
        <!-- Dot -->
        <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-accent border-2 border-surface z-10 mt-1.5"></div>

        <!-- Content -->
        <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${index % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8'}`}>
          <div class="card">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-accent/10 text-accent-light border border-accent/20">
                {exp.period}
              </span>
            </div>
            <h3 class="text-lg font-bold text-slate-100 mb-1">
              {exp.role[locale]}
            </h3>
            <p class="text-sm font-medium text-accent-light mb-2">
              {exp.company[locale]}
            </p>
            <p class="text-sm text-slate-400 mb-3">
              {exp.description[locale]}
            </p>
            <ul class="space-y-1">
              {exp.highlights[locale].map((highlight) => (
                <li class="flex items-start gap-2 text-sm text-slate-400">
                  <span class="text-accent mt-1 shrink-0">&#9656;</span>
                  {highlight}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

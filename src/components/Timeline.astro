---
import type { Locale } from '../i18n/index';
import { experience } from '../content/experience';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';
---

<section id="experience" class="section page-shell">
  <div class="section-header">
    <p class="section-label">03 / {isHe ? 'ניסיון' : 'Experience'}</p>
    <h2 class="display display-lg mt-4 max-w-3xl">
      {isHe
        ? 'תמיכה, פוסט־סייל, IT ותפעול — לאורך 17 שנים.'
        : 'Support, post-sales, IT, and operations — across 17 years.'}
    </h2>
  </div>

  <div class="border-t border-[color:var(--color-rule)]">
    {experience.map((exp) => (
      <article id={`exp-${exp.slug}`} class="entry scroll-mt-28">
        <header>
          <p class="entry-period">{exp.period}</p>
        </header>
        <div>
          <h3 class="entry-role">{exp.role[locale]}</h3>
          <p class="entry-company">{exp.company[locale]}</p>
          <p class="mt-3 text-sm leading-7 text-muted max-w-2xl">{exp.description[locale]}</p>
          {exp.highlights[locale].length > 0 && (
            <ul class="mt-4 space-y-1.5 max-w-2xl">
              {exp.highlights[locale].map((h) => (
                <li class="flex gap-3 text-sm leading-6 text-muted-soft">
                  <span class="mono text-[0.7rem] text-accent pt-1 select-none shrink-0" aria-hidden="true">·</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { experience } from '../content/experience';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="experience" class="section-container">
  <div class="text-center mb-10">
    <h2 class="section-title"><span class="gradient-text">{t(locale, 'experience.title')}</span></h2>
  </div>

  <div class="relative max-w-4xl mx-auto">
    <div class="absolute top-0 bottom-0 left-4 md:left-1/2 md:-translate-x-px w-0.5 bg-gradient-to-b from-indigo-400 via-purple-400 to-cyan-300"></div>

    {experience.map((exp, index) => (
      <div class={`relative flex items-start mb-10 last:mb-0 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
        <div class="absolute left-4 md:left-1/2 -translate-x-1/2 mt-2 w-3 h-3 rounded-full bg-indigo-400 border-2 border-slate-900 light:border-white z-10"></div>

        <div class={`ml-11 md:ml-0 md:w-[calc(50%-1.75rem)] ${index % 2 === 0 ? 'md:mr-auto md:pr-7' : 'md:ml-auto md:pl-7'}`}>
          <div class="card">
            <span class="pill mb-3">{exp.period}</span>
            <h3 class="text-lg font-bold text-slate-100 light:text-slate-900 mb-1">{exp.role[locale]}</h3>
            <p class="text-sm font-semibold text-indigo-300 light:text-indigo-700 mb-2">{exp.company[locale]}</p>
            <p class="text-sm text-slate-400 light:text-slate-600 mb-3">{exp.description[locale]}</p>
            <ul class="space-y-1.5">
              {exp.highlights[locale].map((highlight) => (
                <li class="flex items-start gap-2 text-sm text-slate-300 light:text-slate-700">
                  <span class="text-indigo-300 mt-1 shrink-0">▸</span>
                  {highlight}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

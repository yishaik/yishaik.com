---
import type { Locale } from '../i18n/index';
import { experience } from '../content/experience';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';
---

<section id="experience" class="section page-shell">
  <div class="mb-10 flex items-baseline justify-between gap-6">
    <span class="section-code">§03 / {isHe ? 'ניסיון' : 'EXPERIENCE'}</span>
    <span class="eyebrow hidden sm:inline">
      {isHe ? `${experience.length} תפקידים · 17+ שנים` : `${experience.length} roles · 17+ years`}
    </span>
  </div>

  <div class="grid gap-12 lg:grid-cols-[minmax(0,0.4fr)_minmax(0,0.6fr)] lg:gap-16 mb-10 lg:mb-14">
    <h2 class="display display-md max-w-xl">
      {isHe
        ? 'רצף ארוך של תפקידים ב־IT, enterprise support, ענן ותפעול טכני.'
        : 'A long arc of IT, enterprise support, cloud, and technical operations roles.'}
    </h2>
    <p class="prose-body max-w-xl lg:pt-4">
      {isHe
        ? 'ההיסטוריה הזו חשובה כי היא מצמצמת את הפער בין רעיון למציאות תפעולית — העבודה הנוכחית ב־AI ואוטומציה עומדת על בסיס אמיתי של הפעלה.'
        : 'This history matters because it reduces the gap between idea and production reality — the current AI and automation work sits on a real operational foundation.'}
    </p>
  </div>

  <div class="border-t border-[color:var(--color-rule)]">
    {experience.map((exp) => (
      <article class="entry">
        <header>
          <p class="mono text-xs tracking-[0.1em] text-muted">{exp.period}</p>
        </header>
        <div>
          <h3 class="display text-xl text-ink leading-tight">{exp.role[locale]}</h3>
          <p class="mt-1 text-sm text-accent">{exp.company[locale]}</p>
          <p class="mt-3 text-sm leading-7 text-muted max-w-2xl">{exp.description[locale]}</p>
          {exp.highlights[locale].length > 0 && (
            <ul class="mt-4 space-y-1.5 max-w-2xl">
              {exp.highlights[locale].map((h) => (
                <li class="flex gap-3 text-sm leading-6 text-muted-soft">
                  <span class="mono text-[0.7rem] text-muted pt-1 select-none" aria-hidden="true">·</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

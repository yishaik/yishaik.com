---
import type { Locale } from '../i18n/index';
import { experience } from '../content/experience';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

// Real logos sourced online (rendered monochrome for cohesion); the rest use
// uniform monogram badges.
const logos: Record<string, string> = {
  microsoft: '/logos/microsoft.svg',
  claroty: '/logos/claroty.png',
  profero: '/logos/profero.svg',
  'ajax-union': '/logos/ajax-union.svg',
};

const monograms: Record<string, string> = {
  abra: 'ab',
  'secure-islands': 'SI',
  malam: 'M',
  'bh-comtec': 'BH',
};

// Early-career roles are condensed (no bullet list) to keep the page short.
const condensed = new Set(['ajax-union', 'malam', 'bh-comtec']);
---

<section id="experience" class="tile tile-experience">
  <div class="section-header reveal">
    <p class="section-label">02 / {isHe ? 'ניסיון' : 'Experience'}</p>
    <h2 class="display display-lg mt-4">
      {isHe
        ? 'רצף ארוך של תפקידים — תמיכה, פוסט־סייל, IT ותפעול.'
        : 'A long arc of customer-facing engineering, support, IT, and operations.'}
    </h2>
  </div>

  <div class="border-t border-[color:var(--color-rule)]">
    {experience.map((exp) => (
      <article id={`exp-${exp.slug}`} class="entry scroll-mt-28 reveal">
        <div class="entry-logo-cell">
          {logos[exp.slug] ? (
            <img
              class="entry-logo"
              src={logos[exp.slug]}
              alt={`${exp.company[locale]} logo`}
              loading="lazy"
              decoding="async"
              width="120"
              height="32"
            />
          ) : (
            <span class="logo-badge" aria-hidden="true">
              {monograms[exp.slug] ?? exp.company[locale].slice(0, 1)}
            </span>
          )}
        </div>

        <div class="entry-body">
          <p class="entry-period">{exp.period}</p>
          <h3 class="entry-role">{exp.role[locale]}</h3>
          <p class="entry-company">{exp.company[locale]}</p>
          <p class="mt-2.5 text-[0.95rem] leading-7 text-ink-soft">{exp.description[locale]}</p>
          {!condensed.has(exp.slug) && exp.highlights[locale].length > 0 && (
            <ul class="mt-3 space-y-1.5">
              {exp.highlights[locale].map((h) => (
                <li class="flex gap-3 text-[0.92rem] leading-6 text-muted">
                  <span class="text-accent pt-1.5 select-none shrink-0" aria-hidden="true">
                    <span class="block h-1 w-1 rounded-full bg-current"></span>
                  </span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

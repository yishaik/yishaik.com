---
import type { Locale } from '../i18n/index';
import { experienceContent } from '../content/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = experienceContent.items;
---

<section id="experience" class="tile tile-experience">
  <div class="section-header reveal">
    <p class="section-label">02 / {experienceContent.label[locale]}</p>
    <h2 class="display display-lg mt-4">{experienceContent.heading[locale]}</h2>
  </div>

  <div class="border-t border-[color:var(--color-rule)]">
    {items.map((exp) => (
      <article id={`exp-${exp.slug}`} class="entry scroll-mt-28 reveal">
        <div class="entry-logo-cell">
          {exp.logo && exp.logoType === 'wordmark' && (
            <img class="entry-logo" src={exp.logo} alt={`${exp.company[locale]} logo`} loading="lazy" decoding="async" width="120" height="32" />
          )}
          {exp.logo && exp.logoType === 'square' && (
            <span class="logo-badge logo-badge-img">
              <img class="entry-logo-raster" src={exp.logo} alt={`${exp.company[locale]} logo`} loading="lazy" decoding="async" width="40" height="40" />
            </span>
          )}
          {exp.logo && exp.logoType === 'chip' && (
            <span class="logo-chip">
              <img class="entry-logo-chip" src={exp.logo} alt={`${exp.company[locale]} logo`} loading="lazy" decoding="async" width="120" height="32" />
            </span>
          )}
          {(!exp.logo || exp.logoType === 'monogram') && (
            <span class="logo-badge" aria-hidden="true">
              {exp.monogram || exp.company[locale].slice(0, 2)}
            </span>
          )}
        </div>

        <div class="entry-body">
          <p class="entry-period">{exp.period}</p>
          <h3 class="entry-role">{exp.role[locale]}</h3>
          <p class="entry-company">{exp.company[locale]}</p>
          <p class="mt-2.5 text-[0.95rem] leading-7 text-ink-soft">{exp.description[locale]}</p>
          {!exp.condensed && exp.highlights[locale].length > 0 && (
            <ul class="mt-3 space-y-1.5">
              {exp.highlights[locale].map((h) => (
                <li class="flex gap-3 text-[0.92rem] leading-6 text-muted">
                  <span class="text-accent pt-1.5 select-none shrink-0" aria-hidden="true">
                    <span class="block h-1 w-1 rounded-full bg-current"></span>
                  </span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

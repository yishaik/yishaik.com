---

<section id="contact" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
    <span class="gradient-text">{t(locale, 'contact.title')}</span>
  </h2>
  <p class="text-slate-400 text-center mb-12 max-w-lg mx-auto">
    {t(locale, 'contact.subtitle')}
  </p>

  <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
    <!-- Contact Form -->
    <form
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="space-y-4"
    >
      <div>
        <label for="name" class="block text-sm font-medium text-slate-300 mb-1">
          {t(locale, 'contact.name')}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-2.5 bg-surface-light border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-slate-300 mb-1">
          {t(locale, 'contact.email')}
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-2.5 bg-surface-light border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-slate-300 mb-1">
          {t(locale, 'contact.message')}
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full px-4 py-2.5 bg-surface-light border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full px-6 py-3 bg-accent hover:bg-accent-dark text-white font-medium rounded-lg transition-all hover:shadow-lg hover:shadow-accent/25"
      >
        {t(locale, 'contact.send')}
      </button>
    </form>

    <!-- Social Links -->
    <div class="flex flex-col justify-center">
      <p class="text-sm text-slate-400 mb-6">{t(locale, 'contact.or')}</p>
      <div class="space-y-4">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 rounded-xl bg-surface-light border border-slate-700 hover:border-accent/50 transition-all group"
          >
            <svg class="w-6 h-6 text-slate-400 group-hover:text-accent-light transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d={link.icon} />
            </svg>
            <span class="text-slate-300 group-hover:text-white font-medium transition-colors">
              {link.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

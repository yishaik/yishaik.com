---
import type { Locale } from '../i18n/index';
import { contactContent } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const emailAddress = 'yishai.k@gmail.com';
const mailtoSubject = locale === 'he' ? 'פנייה מהאתר yishaik.com' : 'Inquiry from yishaik.com';
const mailtoBody = locale === 'he'
  ? 'היי ישי,%0A%0Aאני פונה דרך האתר שלך לגבי...%0A'
  : 'Hi Yishai,%0A%0AI am reaching out through your website regarding...%0A';
const mailtoHref = `mailto:${emailAddress}?subject=${mailtoSubject}&body=${mailtoBody}`;

const socialLinks = [
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/yishaik/' },
  { name: 'GitHub', href: 'https://github.com/yishaik' },
  { name: 'Telegram', href: 'https://t.me/yishai_k' },
  { name: 'Email', href: `mailto:${emailAddress}` },
];
---

<section id="contact" class="section-container">
  <div class="max-w-3xl">
    <div class="section-kicker">{contactContent.kicker[locale]}</div>
    <h2 class="section-title mt-5">{contactContent.title[locale]}</h2>
    <p class="section-lede mt-6">{contactContent.intro[locale]}</p>
  </div>

  <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(280px,0.8fr)]">
    <div class="surface-panel p-6 lg:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent-dark dark:text-accent-light">
        {contactContent.directLabel[locale]}
      </p>
      <h3 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-ink">
        {contactContent.directTitle[locale]}
      </h3>
      <ul class="mt-5 space-y-3">
        {contactContent.opportunityTypes[locale].map((item) => (
          <li class="flex gap-3 text-sm leading-7 text-muted sm:text-base">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <a href={mailtoHref} class="button-primary mt-6 w-full sm:w-auto">
        {locale === 'he' ? 'פתח טיוטת אימייל' : 'Open email draft'}
      </a>
      <p class="mt-4 text-sm text-muted break-all">{emailAddress}</p>
    </div>

    <div class="space-y-3">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between rounded-2xl border border-black/8 bg-paper-soft/60 px-5 py-4 text-sm font-medium text-ink transition-colors hover:border-blue-200 hover:text-accent-dark dark:border-white/10 dark:bg-surface-light/80 dark:hover:border-blue-400/30 dark:hover:text-accent-light"
        >
          <span>{link.name}</span>
          <span class="text-muted">↗</span>
        </a>
      ))}
    </div>
  </div>
</section>

---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const stats = [
  { value: t(locale, 'about.stats.projects'), label: t(locale, 'about.stats.projectsLabel') },
  { value: t(locale, 'about.stats.agents'), label: t(locale, 'about.stats.agentsLabel') },
  { value: t(locale, 'about.stats.years'), label: t(locale, 'about.stats.yearsLabel') },
  { value: t(locale, 'about.stats.languages'), label: t(locale, 'about.stats.languagesLabel') },
];
---

<section id="about" class="section-container">
  <h2 class="section-title text-center"><span class="gradient-text">{t(locale, 'about.title')}</span></h2>

  <div class="mt-10 grid lg:grid-cols-[1.2fr_1fr] gap-8 lg:gap-10 items-start">
    <div class="surface-card p-6 md:p-8 space-y-4">
      <p class="text-slate-200 light:text-slate-700 leading-relaxed text-base md:text-lg">{t(locale, 'about.bio')}</p>
      <p class="text-slate-400 light:text-slate-600 leading-relaxed text-base md:text-lg">{t(locale, 'about.bio2')}</p>
    </div>

    <div class="grid grid-cols-2 gap-4">
      {stats.map((stat) => (
        <div class="card text-center">
          <div class="text-3xl md:text-4xl font-black gradient-text mb-1">{stat.value}</div>
          <div class="text-xs md:text-sm text-slate-400 light:text-slate-600">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

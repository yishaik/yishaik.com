---
import type { Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

const narrative = isHe
  ? [
      'אני איש IT ומערכות עם מעל 17 שנות ניסיון, שמתמקד בלהפוך תהליכים מורכבים לזרימות עבודה אמינות ופרקטיות. הרקע שלי כולל הובלת IT, שירותי ענן, אבטחת סייבר, תמיכה ארגונית וביצוע hands-on בארגונים כמו Profero, אברא, קלרוטי, מיקרוסופט ו-Secure Islands.',
      'במקביל לעבודה המקצועית, אני בונה כלים מבוססי AI, מערכות אוטומציה ומוצרים בעברית שנועדו לפתור בעיות עסקיות אמיתיות. היתרון שלי הוא לא רק ב-AI ולא רק ב-IT — הוא בשילוב ביניהם.',
    ]
  : [
      'I\'m an IT and systems professional with 17+ years focused on turning complex operations into reliable, practical workflows. My background spans IT leadership, cloud services, cybersecurity, enterprise support, and hands-on delivery across organizations like Profero, abra, Claroty, Microsoft, and Secure Islands.',
      'Alongside the professional work, I build AI-powered tools, automation systems, and Hebrew-first products. The differentiator is not just AI and not just IT — it is the combination: taking real operational problems, translating them into useful systems, and connecting automation, infrastructure, and delivery that can actually run.',
    ];

const stats = isHe
  ? [
      { value: '17+', label: 'שנים ב־IT, ענן, אבטחה ותפעול' },
      { value: '70+', label: 'פרויקטים ומערכות פנימיות' },
      { value: '50+', label: 'סוכני AI וזרימות אוטומציה' },
      { value: '4', label: 'שפות תכנות בשימוש יומיומי' },
    ]
  : [
      { value: '17+', label: 'years across IT, cloud, security, operations' },
      { value: '70+', label: 'projects and internal systems shipped' },
      { value: '50+', label: 'AI agents and automation workflows' },
      { value: '4', label: 'programming languages in daily use' },
    ];

const principles = isHe
  ? [
      { title: 'AI יישומי, לא דמואים', body: 'ממוקד במערכות שעוזרות לצוותים לעבוד טוב יותר — לא רק בפרוטוטיפים מרשימים.' },
      { title: 'חשיבה מערכתית', body: 'מזהה צווארי בקבוק, ממפה תהליכים, ובונה כלים פנימיים שמורידים חיכוך.' },
      { title: 'עומק תשתיתי', body: 'ניסיון אמיתי בסביבות enterprise — תמיכה בכירה, ענן, אבטחה ותפעול טכני.' },
    ]
  : [
      { title: 'Applied AI, not demo AI', body: 'Focused on systems that help teams operate — not flashy prototypes or one-off chat experiences.' },
      { title: 'Systems thinking', body: 'Find bottlenecks, map workflows, and build internal tools that reduce friction and improve execution speed.' },
      { title: 'Real infrastructure depth', body: 'Hands-on experience from enterprise environments — senior support, cloud, security, and technical operations.' },
    ];
---

<section id="about" class="section page-shell">
  <div class="mb-10 flex items-baseline justify-between gap-6">
    <span class="section-code">§01 / {isHe ? 'אודות' : 'ABOUT'}</span>
    <span class="eyebrow hidden sm:inline">{isHe ? 'מי אני ומה אני עושה' : 'Who I am · what I do'}</span>
  </div>

  <div class="grid gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] lg:gap-20">
    <div>
      <h2 class="display display-md max-w-xl">
        {isHe
          ? 'builder שיודע גם לבנות וגם להפעיל.'
          : 'A builder who knows how to build and how to operate.'}
      </h2>
      <div class="mt-8 space-y-5 prose-body max-w-xl">
        {narrative.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <aside class="lg:pt-10">
      <dl class="divide-y divide-[color:var(--color-rule)] border-y border-[color:var(--color-rule)]">
        {stats.map((s) => (
          <div class="flex items-baseline justify-between gap-6 py-4">
            <dt class="display text-3xl sm:text-4xl text-ink">{s.value}</dt>
            <dd class="mono text-xs text-muted text-end max-w-[14rem] leading-snug tracking-wide">{s.label}</dd>
          </div>
        ))}
      </dl>
    </aside>
  </div>

  <div class="mt-16 grid gap-6 sm:grid-cols-3 lg:mt-20">
    {principles.map((p, i) => (
      <article class="border-t border-[color:var(--color-rule)] pt-5">
        <div class="mono text-[0.68rem] tracking-[0.18em] uppercase text-accent">
          {String(i + 1).padStart(2, '0')}
        </div>
        <h3 class="display text-xl mt-3 text-ink">{p.title}</h3>
        <p class="mt-3 text-sm leading-7 text-muted">{p.body}</p>
      </article>
    ))}
  </div>
</section>

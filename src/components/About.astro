---
import type { Locale } from '../i18n/index';
import { about } from '../content/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="about" class="tile tile-about">
  <div class="section-header reveal">
    <p class="section-label">01 / {about.label[locale]}</p>
    <h2 class="display display-lg mt-4">{about.heading[locale]}</h2>
  </div>

  <div class="grid gap-10 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,0.8fr)] lg:gap-14 items-start">
    <div class="space-y-4 prose-body max-w-2xl reveal">
      {about.narrative.map((p) => <p>{p[locale]}</p>)}
    </div>

    <div class="grid gap-3">
      {about.stats.map((s, i) => (
        <div class="stat-card reveal" style={`--reveal-delay:${i * 90}ms`}>
          <p class="stat-num"><em>{s.value}</em></p>
          <p class="stat-label">{s.label[locale]}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="mt-12 grid gap-4 sm:grid-cols-3 lg:mt-14">
    {about.tracks.map((t, i) => (
      <article class="card reveal" style={`--reveal-delay:${i * 90}ms`}>
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-md bg-accent text-[#faf6ef] dark:text-[#1a1612] font-medium mono text-[0.75rem] tracking-wider">
          {t.code}
        </div>
        <h3 class="display text-lg mt-4 text-ink">{t.title[locale]}</h3>
        <p class="mt-2.5 text-sm leading-6 text-muted">{t.body[locale]}</p>
      </article>
    ))}
  </div>
</section>

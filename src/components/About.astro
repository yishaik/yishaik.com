---
import type { Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

const narrative = isHe
  ? [
      'אני מהנדס ומנהל מערכות עם 17+ שנים, שעבר כל הדרך מתמיכה טכנית ב־Malam, דרך הנדסת פוסט־סייל ב־Secure Islands ותמיכת Premier במיקרוסופט, דרך אסקלציות Tier 3 ב־Claroty, אל ניהול IT ב־Profero. החוט המקשר: עבודה צמודה ללקוח ולמערכת, ואחריות אישית על הפתרון מהאפיון ועד לפרודקשן.',
      'במקביל אני בונה מערכות AI יישומיות, אוטומציות וכלים פנימיים — לרוב בעברית, לרוב סביב בעיות עסקיות אמיתיות. היתרון שלי הוא הצלבה של שלושה דברים שלרוב מפוצלים בין שלושה אנשים: היכרות עם הלקוח, עומק תפעולי, ויכולת הנדסה.',
    ]
  : [
      "I'm a systems engineer and IT manager with 17+ years across the customer-facing side of enterprise software — Malam tech support, Secure Islands post-sales engineering, Microsoft Premier support, Claroty Tier 3 escalations, and IT management at Profero. The through-line is close-to-the-customer, close-to-the-system work, with personal accountability for the outcome from scoping to production.",
      'Alongside that, I build applied AI systems, automations, and internal tools — often Hebrew-first, almost always tied to a concrete business problem. The differentiator is the intersection of three things that usually live with three different people: knowing the customer, understanding the operational reality, and being able to engineer.',
    ];

const stats = isHe
  ? [
      { value: '17+', label: 'שנים ב־IT, support, ענן, ו־AI יישומי' },
      { value: '8', label: 'ארגונים — מסטארט־אפ לארגון enterprise' },
      { value: '3', label: 'פרויקטים פעילים — applied AI ו־automation' },
    ]
  : [
      { value: '17+', label: 'years across IT, support, cloud, applied AI' },
      { value: '8', label: 'organizations — startup through enterprise' },
      { value: '3', label: 'active projects — applied AI and automation' },
    ];

const tracks = isHe
  ? [
      {
        code: 'CS',
        title: 'עומק מול לקוחות',
        body: 'שנים של תמיכה בכירה, פוסט־סייל והטמעה ב־Microsoft, Secure Islands ו־Claroty — אנשים אמיתיים, מערכות אמיתיות, SLA אמיתי.',
      },
      {
        code: 'IT',
        title: 'IT ותפעול טכני',
        body: 'ניהול IT, תשתיות, ענן ו־endpoint — כולל אבטחה, זהויות ועבודה מול מבדקי compliance.',
      },
      {
        code: 'AI',
        title: 'AI יישומי, לא דמואים',
        body: 'מערכות שעוזרות לצוותים לעבוד מהר יותר — RAG, סוכנים, אוטומציה — עם guardrails ועם מבט תפעולי.',
      },
    ]
  : [
      {
        code: 'CS',
        title: 'Customer-facing depth',
        body: 'Years of senior support, post-sales, and implementation work at Microsoft, Secure Islands, and Claroty — real users, real systems, real SLAs.',
      },
      {
        code: 'IT',
        title: 'IT and technical operations',
        body: 'IT management, infrastructure, cloud, and endpoint — with security, identity, and compliance work alongside the day-to-day.',
      },
      {
        code: 'AI',
        title: 'Applied AI, not demo AI',
        body: 'Systems that help teams move — RAG, agents, automation — built with guardrails and an operational mindset.',
      },
    ];
---

<section id="about" class="section page-shell">
  <p class="section-label mb-10">01 / {isHe ? 'אודות' : 'About'}</p>

  <div class="grid gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] lg:gap-16">
    <div>
      <h2 class="display display-md max-w-2xl">
        {isHe
          ? 'מהנדס שגם יודע לבנות וגם יודע להפעיל.'
          : 'A builder who also knows how to operate.'}
      </h2>
      <div class="mt-7 space-y-5 prose-body max-w-2xl">
        {narrative.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <aside class="lg:pt-8">
      <dl class="divide-y divide-[color:var(--color-rule)] border-y border-[color:var(--color-rule)]">
        {stats.map((s) => (
          <div class="flex items-baseline justify-between gap-6 py-4">
            <dt class="display text-3xl sm:text-4xl text-ink">{s.value}</dt>
            <dd class="mono text-xs text-muted text-end max-w-[14rem] leading-snug">{s.label}</dd>
          </div>
        ))}
      </dl>
    </aside>
  </div>

  <div class="mt-14 grid gap-8 sm:grid-cols-3 lg:mt-16">
    {tracks.map((t) => (
      <article class="border-t border-[color:var(--color-rule)] pt-5">
        <div class="mono text-[0.7rem] tracking-[0.14em] uppercase text-accent">
          {t.code}
        </div>
        <h3 class="display text-xl mt-3 text-ink">{t.title}</h3>
        <p class="mt-3 text-sm leading-7 text-muted">{t.body}</p>
      </article>
    ))}
  </div>
</section>

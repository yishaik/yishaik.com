---
import type { Locale } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

const narrative = isHe
  ? [
      'מהנדס ומנהל מערכות עם 17+ שנים — מ־Malam ו־Secure Islands, דרך Microsoft ו־Claroty, ועד ניהול IT ב־Profero. החוט המקשר: עבודה צמודה ללקוח ולמערכת, ואחריות אישית מהאפיון ועד לפרודקשן.',
      'במקביל בונה AI יישומי, אוטומציות וכלים פנימיים — לרוב מחובר לבעיה עסקית אמיתית.',
    ]
  : [
      "Systems engineer and IT manager — 17+ years across Malam, Secure Islands, Microsoft, Claroty, and IT management at Profero. The through-line is close-to-the-customer, close-to-the-system work, with personal accountability from scoping to production.",
      'Alongside that, I build applied AI, automations, and internal tools — almost always tied to a concrete business problem.',
    ];

const stats = isHe
  ? [
      { value: '17+', label: 'שנים ב־IT, support, ענן, ו־AI יישומי' },
      { value: '8', label: 'ארגונים — מסטארט־אפ ל־enterprise' },
      { value: '3', label: 'פרויקטים פעילים — applied AI ו־automation' },
    ]
  : [
      { value: '17+', label: 'years across IT, support, cloud, applied AI' },
      { value: '8', label: 'organizations — startup through enterprise' },
      { value: '3', label: 'active projects — applied AI and automation' },
    ];

const tracks = isHe
  ? [
      {
        code: 'CS',
        title: 'עומק מול לקוחות',
        body: 'תמיכה בכירה, פוסט־סייל והטמעה — Microsoft, Secure Islands, Claroty.',
      },
      {
        code: 'IT',
        title: 'ניהול IT ותפעול',
        body: 'תשתיות, ענן, endpoint, אבטחה ותפעול שוטף.',
      },
      {
        code: 'AI',
        title: 'AI יישומי',
        body: 'RAG, סוכנים, אוטומציה — עם guardrails ומבט תפעולי.',
      },
    ]
  : [
      {
        code: 'CS',
        title: 'Customer-facing depth',
        body: 'Senior support, post-sales, and implementation — Microsoft, Secure Islands, Claroty.',
      },
      {
        code: 'IT',
        title: 'IT and operations',
        body: 'Infrastructure, cloud, endpoint, security, day-to-day operations.',
      },
      {
        code: 'AI',
        title: 'Applied AI',
        body: 'RAG, agents, automation — with guardrails and an operational mindset.',
      },
    ];
---

<section id="about" class="section page-shell">
  <div class="section-header">
    <p class="section-label">01 / {isHe ? 'אודות' : 'About'}</p>
    <h2 class="display display-lg mt-4">
      {isHe
        ? 'מהנדס שגם יודע לבנות וגם יודע להפעיל.'
        : 'A builder who also knows how to operate.'}
    </h2>
  </div>

  <div class="grid gap-10 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,0.8fr)] lg:gap-14 items-start">
    <div class="space-y-4 prose-body max-w-2xl">
      {narrative.map((p) => <p>{p}</p>)}
    </div>

    <div class="grid gap-3">
      {stats.map((s) => (
        <div class="stat-card">
          <p class="stat-num"><em>{s.value}</em></p>
          <p class="stat-label">{s.label}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="mt-12 grid gap-4 sm:grid-cols-3 lg:mt-14">
    {tracks.map((t) => (
      <article class="card">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-md bg-accent text-[#faf6ef] dark:text-[#1a1612] font-medium mono text-[0.75rem] tracking-wider">
          {t.code}
        </div>
        <h3 class="display text-lg mt-4 text-ink">{t.title}</h3>
        <p class="mt-2.5 text-sm leading-6 text-muted">{t.body}</p>
      </article>
    ))}
  </div>
</section>

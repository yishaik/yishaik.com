---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { repositoryHighlights } from '../content/repositories';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="repositories" class="section-container">
  <div class="max-w-3xl">
    <div class="section-kicker">{locale === 'he' ? 'קוד נבחר' : 'Selected repositories'}</div>
    <h2 class="section-title mt-5">{t(locale, 'repositories.title')}</h2>
    <p class="section-lede mt-6">{t(locale, 'repositories.subtitle')}</p>
  </div>

  <div class="mt-10 grid gap-6 lg:grid-cols-3">
    {repositoryHighlights.map((repo) => (
      <article class="card flex h-full flex-col">
        <div class="mb-4 flex items-start justify-between gap-4">
          <h3 class="text-xl font-semibold tracking-[-0.02em] text-ink">{repo.name}</h3>
          <span class="meta-chip">GitHub</span>
        </div>

        <p class="flex-1 text-sm leading-7 text-muted sm:text-base">
          {repo.description[locale]}
        </p>

        <div class="mt-5 flex flex-wrap gap-2">
          {repo.tags.map((tag) => (
            <span class="meta-chip">{tag}</span>
          ))}
        </div>

        <div class="mt-6 flex flex-wrap gap-3 border-t border-black/8 pt-4 dark:border-white/10">
          <a href={repo.github} target="_blank" rel="noopener noreferrer" class="button-primary">
            {t(locale, 'repositories.viewRepo')}
          </a>
          {repo.live && (
            <a href={repo.live} target="_blank" rel="noopener noreferrer" class="button-secondary">
              {t(locale, 'projects.viewLive')}
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

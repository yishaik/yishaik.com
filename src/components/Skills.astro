---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { skillCategories } from '../content/skills';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="skills" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
    <span class="gradient-text">{t(locale, 'skills.title')}</span>
  </h2>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {skillCategories.map((category) => (
      <div class="card group">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">{category.icon}</span>
          <h3 class="text-lg font-semibold text-slate-200">
            {category.name[locale]}
          </h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {category.skills.map((skill) => (
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-accent/10 text-accent-light border border-accent/20 group-hover:bg-accent/20 transition-colors">
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

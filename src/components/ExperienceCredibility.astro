---
import type { Locale } from '../i18n/index';
import { experience } from '../content/experience';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const featuredExperience = experience.slice(0, 5);
---

<section id="experience" class="section-container">
  <div class="max-w-3xl">
    <div class="section-kicker">{locale === 'he' ? 'ניסיון ואמינות' : 'Experience & credibility'}</div>
    <h2 class="section-title mt-5">
      {locale === 'he' ? 'ניסיון מקצועי שמחבר delivery עכשווי עם עומק תפעולי אמיתי.' : 'Professional depth that connects current delivery with real operational experience.'}
    </h2>
    <p class="section-lede mt-6">
      {locale === 'he'
        ? 'מאחורי העבודה הנוכחית יש רצף של תפקידים בסביבות enterprise, תמיכה בכירה, IT, ענן ואבטחה — וזה חלק מרכזי ממה שהופך את הבנייה הטכנית שלי לישימה ואמינה.'
        : 'Behind the current work is a long arc of enterprise support, IT, cloud, and security roles — a big part of what makes the systems work practical, grounded, and trustworthy.'}
    </p>
  </div>

  <div class="mt-10 grid gap-5 lg:grid-cols-2">
    {featuredExperience.map((item) => (
      <article class="card">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <h3 class="text-xl font-semibold tracking-[-0.02em] text-ink">{item.company[locale]}</h3>
            <p class="mt-1 text-sm font-medium text-muted">{item.role[locale]}</p>
          </div>
          <span class="meta-chip">{item.period}</span>
        </div>
        <p class="mt-4 text-sm leading-7 text-muted sm:text-base">{item.description[locale]}</p>
        <ul class="mt-4 space-y-2">
          {item.highlights[locale].slice(0, 3).map((highlight) => (
            <li class="flex gap-3 text-sm leading-7 text-muted">
              <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
              <span>{highlight}</span>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>

---
import type { Locale } from '../i18n/index';
import { experience } from '../content/experience';
import { experienceContent } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const featuredExperience = experience.slice(0, 5);
---

<section id="experience" class="section-container">
  <div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
    <div class="lg:sticky lg:top-28">
      <div class="section-kicker">{experienceContent.kicker[locale]}</div>
      <h2 class="section-title mt-5 max-w-2xl">{experienceContent.title[locale]}</h2>
      <p class="section-lede mt-6 max-w-xl">{experienceContent.intro[locale]}</p>
      <div class="mt-8 flex flex-wrap gap-2">
        {experienceContent.proofStrip[locale].map((item) => (
          <span class="meta-chip">{item}</span>
        ))}
      </div>
    </div>

    <div class="space-y-5">
      {featuredExperience.map((item) => (
        <article class="card">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h3 class="text-xl font-semibold tracking-[-0.02em] text-ink">{item.company[locale]}</h3>
              <p class="mt-1 text-sm font-medium text-muted">{item.role[locale]}</p>
            </div>
            <span class="meta-chip">{item.period}</span>
          </div>
          <p class="mt-4 text-sm leading-7 text-muted sm:text-base">{item.description[locale]}</p>
          <ul class="mt-4 space-y-2">
            {item.highlights[locale].slice(0, 3).map((highlight) => (
              <li class="flex gap-3 text-sm leading-7 text-muted">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

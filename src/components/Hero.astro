---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';
import { heroContent } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="hero" class="section-container pb-16 pt-32 lg:pb-20 lg:pt-40">
  <div class="grid items-end gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)]">
    <div>
      <div class="section-kicker animate-fade-in-up">{heroContent.kicker[locale]}</div>
      <p class="mt-6 text-sm font-semibold uppercase tracking-[0.18em] text-muted animate-fade-in-up animate-delay-100">
        {t(locale, 'hero.name')}
      </p>
      <h1 class="mt-4 max-w-4xl text-5xl font-bold tracking-[-0.05em] text-ink animate-fade-in-up animate-delay-200 sm:text-6xl lg:text-7xl">
        {heroContent.headline[locale]}
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-muted animate-fade-in-up animate-delay-300 sm:text-xl">
        {heroContent.intro[locale]}
      </p>
      <div class="mt-8 flex flex-wrap gap-3 animate-fade-in-up animate-delay-400">
        <a href="#selected-work" class="button-primary">{t(locale, 'hero.cta')}</a>
        <a href="#contact" class="button-secondary">{t(locale, 'hero.contact')}</a>
      </div>
    </div>

    <aside class="surface-panel p-6 lg:p-7 animate-fade-in-up animate-delay-500">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-dark dark:text-accent-light">
        {heroContent.contextLabel[locale]}
      </p>
      <h2 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-ink">
        {heroContent.contextTitle[locale]}
      </h2>
      <ul class="mt-5 space-y-4">
        {heroContent.contextPoints[locale].map((item) => (
          <li class="flex gap-3 text-sm leading-7 text-muted sm:text-base">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</section>

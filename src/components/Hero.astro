---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-surface via-indigo-950/20 to-surface animate-gradient"></div>

  <!-- Decorative grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>

  <!-- Floating orbs -->
  <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 section-container text-center">
    <!-- Greeting -->
    <p class="text-lg md:text-xl text-slate-400 mb-2 animate-fade-in-up">
      {t(locale, 'hero.greeting')}
    </p>

    <!-- Name -->
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold mb-4 animate-fade-in-up animate-delay-100">
      <span class="gradient-text">{t(locale, 'hero.name')}</span>
    </h1>

    <!-- Title -->
    <h2 class="text-xl sm:text-2xl md:text-3xl font-medium text-slate-200 mb-6 animate-fade-in-up animate-delay-200">
      {t(locale, 'hero.title')}
    </h2>

    <!-- Subtitle -->
    <p class="max-w-2xl mx-auto text-base md:text-lg text-slate-400 mb-10 animate-fade-in-up animate-delay-300">
      {t(locale, 'hero.subtitle')}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap gap-4 justify-center animate-fade-in-up animate-delay-400">
      <a
        href="#projects"
        class="px-8 py-3 bg-accent hover:bg-accent-dark text-white font-medium rounded-xl transition-all hover:shadow-lg hover:shadow-accent/25"
      >
        {t(locale, 'hero.cta')}
      </a>
      <a
        href="#contact"
        class="px-8 py-3 border border-slate-600 hover:border-accent text-slate-300 hover:text-white font-medium rounded-xl transition-all"
      >
        {t(locale, 'hero.contact')}
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

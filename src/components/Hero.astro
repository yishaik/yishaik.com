---
import type { Locale } from '../i18n/index';
import { heroContent, roleTracks } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

const headline = isHe
  ? 'הנדסת Customer Success, ניהול IT ו־AI יישומי — בנייה והפעלה מקצה לקצה.'
  : 'Customer Success engineering, IT management, and applied AI — built and operated end-to-end.';

const ctas = isHe
  ? { primary: 'בוא נדבר', secondary: 'ראה עבודות' }
  : { primary: 'Start a conversation', secondary: 'See selected work' };

const statusText = isHe
  ? 'פתוח לתפקידים חדשים · ישראל · מרחוק־פרוש'
  : 'Open to new roles · Israel · Remote-friendly';

const openForLabel = isHe ? 'פתוח ל · קפוץ להוכחה' : 'Open for · jump to proof';
---

<section id="cover" class="section page-shell pt-28 lg:pt-32">
  <p class="eyebrow mb-5">{heroContent.kicker[locale]}</p>

  <h1 class="display display-xl max-w-4xl">{headline}</h1>

  <p class="prose-lede mt-6 max-w-2xl">{heroContent.intro[locale]}</p>

  <div class="mt-8 flex flex-wrap items-center gap-3">
    <a href="#contact" class="btn btn-primary">
      {ctas.primary}
      <span aria-hidden="true">→</span>
    </a>
    <a href="#work" class="btn btn-ghost">
      {ctas.secondary}
    </a>
  </div>

  <p class="mt-7 inline-flex items-center gap-2 mono text-xs text-muted">
    <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
    {statusText}
  </p>

  <div class="mt-12 lg:mt-16">
    <p class="mono text-[0.7rem] tracking-[0.14em] uppercase text-muted mb-4">
      {openForLabel}
    </p>
    <div class="grid gap-3 sm:grid-cols-2">
      {roleTracks.map((track) => (
        <a href={track.href} class="track-card">
          <span class="track-code" aria-hidden="true">{track.code}</span>
          <span class="track-label">{track.label[locale]}</span>
        </a>
      ))}
    </div>
  </div>
</section>

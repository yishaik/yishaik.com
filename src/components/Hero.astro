---
import type { Locale } from '../i18n/index';
import { hero } from '../content/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const kickerParts = hero.kicker[locale].split('·').map((s) => s.trim());
---

<section id="cover" class="tile tile-hero">
  <p class="status-pill reveal mb-5">
    <span class="status-dot" aria-hidden="true"></span>
    {hero.status[locale]}
  </p>

  <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1.5 mb-5 reveal" style="--reveal-delay:60ms">
    {kickerParts.map((part, i) => (
      <>
        {i > 0 && <span class="text-accent/60 mono text-[0.7rem]" aria-hidden="true">/</span>}
        <span class="eyebrow">{part}</span>
      </>
    ))}
  </div>

  <h1 class="display display-xl reveal" style="--reveal-delay:120ms">
    {hero.headlineLead[locale]}<span class="text-gradient">{hero.headlineAccent[locale]}</span>
  </h1>

  <p class="prose-lede mt-5 max-w-2xl reveal" style="--reveal-delay:200ms">
    {hero.intro[locale]}
  </p>

  <div class="mt-7 flex flex-wrap items-center gap-3 reveal" style="--reveal-delay:280ms">
    <a href="#contact" class="btn btn-primary">
      {hero.ctaPrimary[locale]}
      <span aria-hidden="true">→</span>
    </a>
    <a href="#experience" class="btn btn-ghost">
      {hero.ctaSecondary[locale]}
      <span aria-hidden="true">↓</span>
    </a>
  </div>

  <div class="mt-9 reveal" style="--reveal-delay:360ms">
    <p class="eyebrow mb-3.5">{hero.previouslyAtLabel[locale]}</p>
    <div class="logo-strip">
      {hero.previousLogos.map((logo) => (
        <img
          class="strip-logo"
          src={logo.src}
          alt={logo.name}
          loading="lazy"
          decoding="async"
          width="120"
          height="28"
        />
      ))}
    </div>
  </div>
</section>

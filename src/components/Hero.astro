---
import type { Locale } from '../i18n/index';
import { heroContent, roleTracks } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

const headline = isHe
  ? 'הנדסת Customer Success, ניהול IT ו־AI יישומי — בנייה והפעלה מקצה לקצה.'
  : 'Customer Success engineering, IT management, and applied AI — built and operated end-to-end.';

const status = isHe
  ? { key: 'STATUS', value: 'פתוח לתפקידים חדשים · ישראל · מרחוק־פרוש' }
  : { key: 'STATUS', value: 'Open to new roles · Israel · Remote-friendly' };

const ctas = isHe
  ? { primary: 'בוא נדבר', secondary: 'ראה עבודות' }
  : { primary: 'Start a conversation', secondary: 'See selected work' };

const openForLabel = isHe ? 'פתוח ל' : 'Open for';
---

<section id="cover" class="section page-shell pt-28 lg:pt-36">
  <p class="section-label mb-10">00 / {isHe ? 'פתיחה' : 'Cover'}</p>

  <div class="grid gap-12 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,0.6fr)] lg:gap-16 lg:items-start">
    <div>
      <p class="eyebrow mb-5">{heroContent.kicker[locale]}</p>
      <h1 class="display display-lg max-w-4xl">{headline}</h1>
      <p class="prose-lede mt-7 max-w-2xl">
        {heroContent.intro[locale]}
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="#contact" class="btn btn-primary">
          {ctas.primary}
          <span aria-hidden="true">→</span>
        </a>
        <a href="#work" class="btn btn-ghost">
          {ctas.secondary}
        </a>
      </div>
      <p class="mt-8 mono text-xs text-muted">
        <span class="text-accent">·</span> {status.value}
      </p>
    </div>

    <aside class="lg:pt-2">
      <p class="mono text-[0.7rem] tracking-[0.16em] uppercase text-muted">
        {openForLabel}
      </p>
      <ul class="mt-4 divide-y divide-[color:var(--color-rule)] border-y border-[color:var(--color-rule)]">
        {roleTracks.map((track) => (
          <li class="flex items-baseline gap-4 py-3">
            <span class="mono text-[0.7rem] tracking-[0.12em] text-accent shrink-0 w-6">
              {track.code}
            </span>
            <span class="text-sm text-ink leading-snug">{track.label[locale]}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</section>

---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="hero" class="section-container min-h-[88vh] flex items-center">
  <div class="w-full grid lg:grid-cols-[1.4fr_1fr] gap-10 items-center">
    <div>
      <p class="text-base md:text-lg text-slate-400 light:text-slate-600 mb-4 animate-fade-in-up">{t(locale, 'hero.greeting')}</p>
      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black leading-tight mb-4 animate-fade-in-up animate-delay-100">
        <span class="gradient-text">{t(locale, 'hero.name')}</span>
      </h1>
      <h2 class="text-xl sm:text-2xl lg:text-3xl font-semibold text-slate-100 light:text-slate-900 mb-4 animate-fade-in-up animate-delay-200">
        {t(locale, 'hero.title')}
      </h2>
      <p class="max-w-2xl text-base md:text-lg text-slate-400 light:text-slate-600 mb-9 animate-fade-in-up animate-delay-300">
        {t(locale, 'hero.subtitle')}
      </p>
      <div class="flex flex-wrap gap-3 animate-fade-in-up animate-delay-400">
        <a href="#projects" class="px-6 py-3 rounded-xl bg-accent hover:bg-accent-dark text-white font-semibold transition-colors">
          {t(locale, 'hero.cta')}
        </a>
        <a href="#contact" class="px-6 py-3 rounded-xl border border-slate-600/80 light:border-slate-300 text-slate-200 light:text-slate-700 hover:border-indigo-400 transition-colors">
          {t(locale, 'hero.contact')}
        </a>
      </div>
    </div>

    <div class="surface-card p-7 lg:p-8">
      <p class="pill mb-4">{locale === 'he' ? 'פוקוס נוכחי' : 'Current focus'}</p>
      <ul class="space-y-4 text-sm md:text-base text-slate-300 light:text-slate-700">
        <li class="flex gap-3"><span class="text-indigo-300">✦</span><span>{locale === 'he' ? 'בניית מערכות AI מרובות סוכנים בסקייל' : 'Building production multi-agent AI systems'}</span></li>
        <li class="flex gap-3"><span class="text-indigo-300">✦</span><span>{locale === 'he' ? 'ארכיטקטורת Full-stack נקייה וניתנת להרחבה' : 'Designing clean, scalable full-stack architecture'}</span></li>
        <li class="flex gap-3"><span class="text-indigo-300">✦</span><span>{locale === 'he' ? 'ייעול צוותים עם אוטומציה וכלי מפתחים' : 'Accelerating teams with automation and dev tooling'}</span></li>
      </ul>
    </div>
  </div>
</section>

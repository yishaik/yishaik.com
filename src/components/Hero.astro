---
import type { Locale } from '../i18n/index';
import { heroContent, roleTracks } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';

// Headline split so the closing phrase can carry the animated gradient accent.
const headlineLead = isHe
  ? 'הנדסת Customer Success, ניהול IT ו־AI יישומי — '
  : 'Customer Success engineering, IT management, and applied AI — ';
const headlineAccent = isHe
  ? 'בנייה והפעלה מקצה לקצה.'
  : 'built and operated end-to-end.';

const ctas = isHe
  ? { primary: 'בוא נדבר', secondary: 'ראה עבודות' }
  : { primary: 'Start a conversation', secondary: 'See selected work' };

const statusText = isHe
  ? 'פתוח לתפקידים חדשים · ישראל · מרחוק־פרוש'
  : 'Open to new roles · Israel · Remote-friendly';

const openForLabel = isHe ? 'פתוח ל · קפוץ להוכחה' : 'Open for · jump to proof';

const kickerParts = heroContent.kicker[locale].split('·').map((s) => s.trim());
---

<section id="cover" class="tile tile-hero">
  <p class="status-pill reveal mb-5">
    <span class="status-dot" aria-hidden="true"></span>
    {statusText}
  </p>

  <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1.5 mb-5 reveal" style="--reveal-delay:60ms">
    {kickerParts.map((part, i) => (
      <>
        {i > 0 && <span class="text-accent/60 mono text-[0.7rem]" aria-hidden="true">/</span>}
        <span class="eyebrow">{part}</span>
      </>
    ))}
  </div>

  <h1 class="display display-xl max-w-5xl reveal" style="--reveal-delay:120ms">
    {headlineLead}<span class="text-gradient">{headlineAccent}</span>
  </h1>

  <p class="prose-lede mt-5 max-w-2xl reveal" style="--reveal-delay:200ms">
    {heroContent.intro[locale]}
  </p>

  <div class="mt-6 flex flex-wrap items-center gap-3 reveal" style="--reveal-delay:280ms">
    <a href="#contact" class="btn btn-primary">
      {ctas.primary}
      <span aria-hidden="true">→</span>
    </a>
    <a href="#work" class="btn btn-ghost">
      {ctas.secondary}
      <span aria-hidden="true">↓</span>
    </a>
  </div>

  <div class="mt-8 lg:mt-10 reveal" style="--reveal-delay:360ms">
    <p class="mono text-[0.7rem] tracking-[0.14em] uppercase text-muted mb-3">
      {openForLabel}
    </p>
    <div class="grid gap-2 sm:grid-cols-2 xl:grid-cols-4">
      {roleTracks.map((track, i) => (
        <a href={track.href} class="track-card reveal" style={`--reveal-delay:${400 + i * 70}ms`}>
          <span class="track-code" aria-hidden="true">{track.code}</span>
          <span class="track-label">{track.label[locale]}</span>
        </a>
      ))}
    </div>
  </div>
</section>

---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-black/8 bg-paper-soft/50 dark:border-white/10 dark:bg-surface-light/70">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-8 text-sm sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
    <p class="text-muted">
      &copy; {currentYear} {t(locale, 'hero.name')}. {t(locale, 'footer.rights')}
    </p>
    <p class="text-muted/90">{t(locale, 'footer.built')}</p>
  </div>
</footer>

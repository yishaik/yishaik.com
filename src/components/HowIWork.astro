---
import type { Locale } from '../i18n/index';
import { principles } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';
---

<section id="how-i-work" class="section page-shell">
  <div class="section-header">
    <p class="section-label">02 / {isHe ? 'איך אני עובד' : 'How I work'}</p>
    <h2 class="display display-lg mt-4 max-w-2xl">
      {isHe
        ? 'חמישה דברים שאני מנסה לכבד.'
        : 'Five things I try to honor.'}
    </h2>
    <p class="prose-body mt-4 max-w-xl">
      {isHe
        ? 'לא מניפסט, ולא רשימה שאפתנית — רק האופן שבו אני באמת ניגש לעבודה.'
        : 'Not a manifesto, not an aspirational list — just how I actually approach the work.'}
    </p>
  </div>

  <ol class="grid gap-3 sm:grid-cols-2">
    {principles.map((p, i) => (
      <li class="card flex gap-4">
        <span class="mono text-[0.85rem] font-medium text-accent shrink-0 tabular-nums leading-7">
          {String(i + 1).padStart(2, '0')}
        </span>
        <p class="text-[0.95rem] leading-7 text-ink-soft">
          {p.body[locale]}
        </p>
      </li>
    ))}
  </ol>
</section>

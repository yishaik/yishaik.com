---
import type { Locale } from '../i18n/index';
import { principles } from '../content/homepageContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isHe = locale === 'he';
---

<section id="how-i-work" class="section page-shell">
  <p class="section-label mb-10">02 / {isHe ? 'איך אני עובד' : 'How I work'}</p>

  <div class="grid gap-12 lg:grid-cols-[minmax(0,0.4fr)_minmax(0,0.6fr)] lg:gap-14">
    <div>
      <h2 class="display display-md max-w-md">
        {isHe
          ? 'חמישה דברים שאני מנסה לכבד.'
          : 'Five things I try to honor.'}
      </h2>
      <p class="prose-body mt-5 max-w-md">
        {isHe
          ? 'לא מניפסט, ולא רשימה שאפתנית — רק האופן שבו אני באמת ניגש לעבודה.'
          : 'Not a manifesto, not an aspirational list — just how I actually approach the work.'}
      </p>
    </div>

    <ol class="border-t border-[color:var(--color-rule)]">
      {principles.map((p, i) => (
        <li class="grid gap-3 border-b border-[color:var(--color-rule)] py-5 md:grid-cols-[minmax(3rem,4rem)_1fr] md:gap-8 md:py-6">
          <span class="mono text-[0.7rem] tracking-[0.14em] uppercase text-accent">
            {String(i + 1).padStart(2, '0')}
          </span>
          <p class="text-[0.98rem] leading-7 text-ink-soft max-w-2xl">
            {p.body[locale]}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>

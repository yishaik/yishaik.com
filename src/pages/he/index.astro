---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProofStrip from '../../components/ProofStrip.astro';
import WhyYishai from '../../components/WhyYishai.astro';
import SelectedWork from '../../components/SelectedWork.astro';
import ExperienceCredibility from '../../components/ExperienceCredibility.astro';
import Contact from '../../components/Contact.astro';

const locale = 'he' as const;
---

<BaseLayout locale={locale}>
  <Hero locale={locale} />
  <ProofStrip locale={locale} />
  <WhyYishai locale={locale} />
  <SelectedWork locale={locale} />
  <ExperienceCredibility locale={locale} />
  <Contact locale={locale} />
</BaseLayout>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { experience } from '../content/experience';
import type { Locale } from '../i18n/index';
import { t, getDir } from '../i18n/index';

interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
}

const { locale = 'en', title, description } = Astro.props;
const dir = getDir(locale);
const siteOrigin = 'https://yishaik.com';
const siteTitle = title || `${t(locale, 'hero.name')} — ${t(locale, 'hero.title')}`;
const siteDescription = description || t(locale, 'hero.subtitle');
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const isHebrewPath = currentPath === '/he/' || currentPath.startsWith('/he/');
const canonicalPath = currentPath;
const alternatePath = isHebrewPath
  ? currentPath.replace(/^\/he/, '') || '/'
  : `/he${currentPath === '/' ? '/' : currentPath}`;
const canonicalUrl = new URL(canonicalPath, siteOrigin).toString();
const alternateUrl = new URL(alternatePath, siteOrigin).toString();
const xDefaultUrl = new URL('/', siteOrigin).toString();
const ogImageUrl = new URL('/social-card.svg', siteOrigin).toString();
const localeTag = locale === 'he' ? 'he_IL' : 'en_US';
const alternateLocaleTag = locale === 'he' ? 'en_US' : 'he_IL';

const knowsAbout = [
  'Customer Success Engineering',
  'Technical Account Management',
  'Implementation Engineering',
  'Enterprise Technical Support',
  'IT Management',
  'Technical Operations',
  'Cloud Infrastructure',
  'Identity and Access Management',
  'Microsoft 365',
  'Cybersecurity',
  'Applied AI',
  'AI Engineering',
  'AI Automation',
  'Multi-Agent Systems',
  'Retrieval Augmented Generation',
  'Internal Tools',
  'Software Engineering',
];

const personId = `${siteOrigin}/#person`;
const websiteId = `${siteOrigin}/#website`;
const profileId = `${canonicalUrl}#profile`;

const employerSeen = new Set<string>();
const employers = experience
  .map((e) => ({ name: e.company.en, role: e.role.en }))
  .filter((e) => {
    if (employerSeen.has(e.name)) return false;
    employerSeen.add(e.name);
    return true;
  });

const jsonLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: `${siteOrigin}/`,
      name: 'Yishai Kaminsky',
      inLanguage: ['en', 'he'],
      publisher: { '@id': personId },
    },
    {
      '@type': 'ProfilePage',
      '@id': profileId,
      url: canonicalUrl,
      name: siteTitle,
      description: siteDescription,
      inLanguage: locale === 'he' ? 'he' : 'en',
      isPartOf: { '@id': websiteId },
      about: { '@id': personId },
      mainEntity: { '@id': personId },
    },
    {
      '@type': 'Person',
      '@id': personId,
      name: t(locale, 'hero.name'),
      url: `${siteOrigin}/`,
      jobTitle: t(locale, 'hero.title'),
      description: siteDescription,
      image: ogImageUrl,
      knowsLanguage: ['en', 'he'],
      knowsAbout,
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'IL',
        addressRegion: 'Tel Aviv District',
      },
      alumniOf: employers.map((e) => ({
        '@type': 'Organization',
        name: e.name,
      })),
      sameAs: [
        'https://github.com/yishaik',
        'https://www.linkedin.com/in/yishaik/',
        'https://t.me/yishai_k',
      ],
      seeks: {
        '@type': 'Demand',
        name: 'Open to new roles',
        description:
          'Open to Customer Success engineering, IT management, AI engineering, and independent project work — full-time, hybrid, remote, or on-site (Tel Aviv area).',
      },
    },
  ],
};
---

<!doctype html>
<html lang={locale} dir={dir} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDescription} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#f5f1e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#100d09" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={locale === 'he' ? 'en' : 'he'} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="yishaik.com" />
    <meta property="og:locale" content={localeTag} />
    <meta property="og:locale:alternate" content={alternateLocaleTag} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={siteTitle} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="profile:first_name" content={locale === 'he' ? 'ישי' : 'Yishai'} />
    <meta property="profile:last_name" content={locale === 'he' ? 'קמינסקי' : 'Kaminsky'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={siteTitle} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Heebo:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/llms.txt" href="/llms.txt" />
    <title>{siteTitle}</title>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />

    <script is:inline>
      const theme = localStorage.getItem('theme') || 'light';
      document.documentElement.classList.remove('light', 'dark');
      document.documentElement.classList.add(theme);
    </script>
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
